# Pipeline environment variables — copy to .env and fill in your values
# source /home/lpantano/pipelines/.env

export GCP_PROJECT=""
export GCP_REGION="us-east1"
export GCP_WORK_DIR=""           # e.g. gs://my-bucket/scratch
export ARTIFACT_REGISTRY="us-docker.pkg.dev"
export PIPELINES_DIR="$HOME/pipelines"
